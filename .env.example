# Stripe Keys — get these from https://dashboard.stripe.com/apikeys
# Publishable key is safe to expose in the frontend (prefixed with VITE_ for Vite)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key — NEVER expose this in the frontend
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — get this from the Stripe CLI:
#   stripe listen --forward-to localhost:3000/api/webhooks
# Or from the Stripe Dashboard under Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
